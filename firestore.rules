rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow authenticated users with @arad.digital email
    function isAradUser() {
      return request.auth != null &&
             request.auth.token.email.matches('.*@arad\\.digital$');
    }

    // All collections - allow read/write for authenticated arad.digital users
    match /{collection}/{docId} {
      allow read, write: if isAradUser();
    }

    // Nested subcollections
    match /{collection}/{docId}/{subcollection}/{subDocId} {
      allow read, write: if isAradUser();
    }
  }
}
